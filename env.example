# Database
POSTGRES_HOST=truman-postgres.truman.svc.cluster.local
POSTGRES_DB=trumandb
POSTGRES_USER=truman
POSTGRES_PASSWORD=password

# API Configuration
Authentication__Jwt__Key=your-secret-key-here
Authentication__Jwt__Issuer=truman-api
Authentication__Jwt__Audience=truman-web

# OAuth Providers
Authentication__Facebook__AppId=your-facebook-app-id
Authentication__Facebook__AppSecret=your-facebook-app-secret
Authentication__Google__ClientId=your-google-client-id
Authentication__Google__ClientSecret=your-google-client-secret

# Email
Email__Brevo__ApiKey=your-brevo-api-key
Email__Brevo__MagicLinkTemplateId=1

# Frontend
Frontend__BaseUrl=http://localhost:3000

# AI Configuration
AI__Model=gemini-2.5-flash-lite-preview-06-17
AI__ApiKey=your-ai-api-key 

# Sentry
Sentry__Dsn=your_sentry_dsn